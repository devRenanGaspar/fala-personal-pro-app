# Supabase — copie este arquivo para `.env` e preencha com os dados do seu projeto.
# A chave "publishable"/anon é pública por design (vai para o browser) e é
# protegida pelas políticas de RLS do Supabase.
# NUNCA coloque aqui a service_role key nem segredos de Edge Functions/n8n —
# esses ficam apenas no painel do Supabase (Project Settings → Functions → Secrets).

VITE_SUPABASE_URL="https://<seu-project-ref>.supabase.co"
VITE_SUPABASE_PROJECT_ID="<seu-project-ref>"
VITE_SUPABASE_PUBLISHABLE_KEY="<sua-chave-anon-publishable>"

# (Opcional) Link de suporte exibido na tela de login.
# Ex.: https://wa.me/55DDNUMERO — se ausente, usa um placeholder.
VITE_SUPPORT_WHATSAPP_URL=""
